{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/stylelint-config-holy-grail/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "postcss": "^8.5.15",
        "postcss-scss": "^4.0.9",
        "stylelint-order": "^8.1.1",
        "stylelint-scss": "^7.2.0"
    },
    "description": "This is my personal stylelint configuration.",
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-angular": "^21.0.2",
        "chai": "^5.2.1",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "mocha": "^11.7.5",
        "prettier": "^3.8.3",
        "stylelint": "^17.11.0"
    },
    "engines": {
        "node": ">=22.22.2"
    },
    "files": [
        "src/"
    ],
    "homepage": "https://github.com/chrisguttandin/stylelint-config-holy-grail",
    "keywords": [
        "stylelint",
        "stylelint-config"
    ],
    "license": "MIT",
    "main": "src/module.js",
    "name": "stylelint-config-holy-grail",
    "peerDependencies": {
        "stylelint": "^17.11.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/stylelint-config-holy-grail.git"
    },
    "scripts": {
        "lint": "npm run lint:config && npm run lint:src && npm run lint:test",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "eslint --config config/eslint/src.mjs --ext .js --report-unused-disable-directives src/",
        "lint:test": "eslint --config config/eslint/test.mjs --ext .js --report-unused-disable-directives test/",
        "prepare": "husky",
        "test": "npm run lint && npm run test:integration",
        "test:integration": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"integration\" ]; then mocha --bail --parallel --recursive --require config/mocha/config-integration.mjs test/integration; fi"
    },
    "version": "13.0.1"
}
